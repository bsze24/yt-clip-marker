{
  "manifest_version": 3,
  "name": "YouTube Clip Marker",
  "version": "0.0.1",
  "description": "Mark and export clip ranges from YouTube videos.",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
